# ============================================================
# GeoLet — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file to version control.
# ============================================================

# -------------------------------------------------------
# Backend (FastAPI)
# -------------------------------------------------------

# Comma-separated list of allowed CORS origins for the API server.
# In production, replace with your deployed frontend domain.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# NewsAPI.org API key for fetching live geopolitical news.
# Get a free key at: https://newsapi.org/
NEWS_API_KEY=your_news_api_key_here

# -------------------------------------------------------
# Frontend (Vite)
# -------------------------------------------------------

# Base URL of the backend API (used for production builds).
# In development this is handled by the Vite proxy.
VITE_API_URL=http://localhost:8000
